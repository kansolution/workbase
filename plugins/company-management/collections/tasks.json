        "x-component-props": { "min": 1 }
      }
    },
    {
      "type": "date",
      "name": "due_date",
      "allowNull": true,
      "interface": "datetime",
      "uiSchema": {
        "type": "string",
        "title": "Hạn hoàn thành",
        "description": "Chỉ áp dụng khi task_type = Riêng",
