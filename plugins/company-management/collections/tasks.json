{
  "name": "tasks",
  "title": "Công việc",
  "uiManageable": true,
  "fields": [
    {
      "type": "string",
      "name": "title",
      "interface": "input",
      "uiSchema": {
        "type": "string",
        "title": "Tiêu đề",
        "x-component": "Input",
        "required": true
      }
    },
    {
      "type": "string",
      "name": "task_type",
      "interface": "select",
      "uiSchema": {
        "type": "string",
        "title": "Loại công việc",
        "x-component": "Select",
        "required": true,
        "enum": [
          { "label": "Định kỳ", "value": "Định kỳ", "color": "blue" },
          { "label": "Riêng", "value": "Riêng", "color": "green" }
        ]
      }
    },
    {
      "type": "text",
      "name": "description",
      "interface": "richText",
