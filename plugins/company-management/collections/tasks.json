        "x-component": "Select",
        "description": "Chỉ áp dụng khi task_type = Định kỳ",
        "enum": [
          { "label": "Ngày", "value": "Ngày", "color": "blue" },
          { "label": "Tuần", "value": "Tuần", "color": "purple" }
        ]
      }
    },
    {
      "type": "integer",
      "name": "recurrence_frequency",
      "allowNull": true,
      "interface": "number",
      "uiSchema": {
        "type": "number",
