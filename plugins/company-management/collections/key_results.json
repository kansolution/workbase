  "fields": [
    {
      "type": "belongsTo",
      "name": "objective",
      "target": "objectives",
      "foreignKey": "objectiveId",
      "targetKey": "id",
      "interface": "m2o",
      "uiSchema": {
        "title": "Mục tiêu",
        "required": true,
        "x-component": "AssociationField",
        "x-component-props": {
          "multiple": false,
          "fieldNames": { "label": "title", "value": "id" }
        }
      }
    },
    {
      "type": "string",
      "name": "title",
