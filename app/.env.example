# Copy this file to ".env" in the same folder (app/.env) and fill in real values.
# app/.env is gitignored and must NEVER be committed.

# --- NocoBase application ---
# Random secret used to sign sessions/tokens. Generate your own, e.g.:
#   openssl rand -hex 32
APP_KEY=replace-with-a-long-random-string
APP_ENV=production
APP_LANG=en-US

# --- PostgreSQL connection (shared by the "app" and "postgres" services) ---
DB_DATABASE=nocobase
DB_USER=nocobase
DB_PASSWORD=replace-with-a-strong-password
